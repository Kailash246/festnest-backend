# ─── FestNest Backend – Environment Variables ───────────────────────────
# Copy this file to .env and fill in every value before running the server.

# ── Server ──────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=5000

# Frontend origin allowed by CORS (use CLIENT_URL for production deploys)
CLIENT_URL=
CLIENT_ORIGIN=http://localhost:5173

# ── MongoDB Atlas ────────────────────────────────────────────────────────
MONGODB_URI=

# ── JWT ──────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=
JWT_ACCESS_EXPIRES_IN=15m

JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRES_IN=30d

# ── Email ────────────────────────────────────────────────────────────────
# Option 1 (recommended for production/Render): Resend API — https://resend.com
RESEND_API_KEY=
MAIL_FROM=FestNest <onboarding@resend.dev>

# Option 2 (local dev only — blocked by most cloud hosts): Nodemailer SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# ── Cloudinary ───────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
